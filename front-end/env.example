# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://localhost:3000

# Microsoft Entra ID Configuration
AUTH_MICROSOFT_ENTRA_ID_ID=your-client-id-here
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-client-secret-here
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/organizations/v2.0

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the placeholder values with your actual Azure AD app registration details
# 3. Get these values from the Azure Portal > App registrations > Your app > Overview
# 4. For NEXTAUTH_SECRET, generate a random string (you can use: openssl rand -base64 32)
# 5. For AUTH_MICROSOFT_ENTRA_ID_ISSUER, replace 'your-tenant-id-here' with your actual tenant ID
